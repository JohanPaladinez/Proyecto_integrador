#include <WiFi.h>
#include <math.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// -------------------------
// Pines
// -------------------------
static const uint8_t DS18B20_PIN = 21;

static const uint8_t RELAY1_PIN = 32;
static const uint8_t RELAY2_PIN = 33;
static const bool RELAY_ACTIVE_HIGH = true;

static const uint8_t BUTTON_PIN = 4;

static const uint8_t LED_R_PIN = 25;
static const uint8_t LED_G_PIN = 27;
static const uint8_t LED_B_PIN = 26;

static const uint8_t CURRENT_PIN = 34;

// -------------------------
// Tiempos
// -------------------------
static const unsigned long TIEMPO_ESPERA_MS   = 15000UL;    // 15 s
static const unsigned long TIEMPO_LIMPIEZA_MS = 120000UL;   // 2 min
static const unsigned long TIEMPO_FINAL_MS    = 5000UL;     // 5 s

static const unsigned long INTERVALO_TEMP_MS = 600000UL;
static const unsigned long DEBOUNCE_MS = 200UL;

// -------------------------
// Corriente
// -------------------------
static const float SENSOR_SENSITIVITY = 0.066f;
static const float VREF = 3.3f;
static const int ADC_MAX_VALUE = 4095;
static const int WINDOW_SIZE = 200;
static const float LIMITE_SOBRECORRIENTE_RMS = 10.0f;

// -------------------------
// Objetos
// -------------------------
OneWire oneWire(DS18B20_PIN);
DallasTemperature sensors(&oneWire);

// -------------------------
// Estados
// -------------------------
enum EstadoSistema {
  ESPERA = 0,
  LIMPIANDO,
  FINALIZADO,
  FALLO
};

EstadoSistema estadoActual = ESPERA;

// -------------------------
unsigned long tInicioEstado = 0;
unsigned long tUltimoBoton = 0;
unsigned long tUltimaTemp = 0;

float currentOffset = 0.0f;
float samples[WINDOW_SIZE] = {0};
int sampleIndex = 0;
float currentRMS = 0.0f;

// -------------------------
// Utilidades
// -------------------------
void setRGB(bool r, bool g, bool b) {
  digitalWrite(LED_R_PIN, r);
  digitalWrite(LED_G_PIN, g);
  digitalWrite(LED_B_PIN, b);
}

void setRelay(bool on) {
  digitalWrite(RELAY1_PIN, on ? LOW : HIGH);
  digitalWrite(RELAY2_PIN, on ? LOW : HIGH);
}

// -------------------------
// Corriente
// -------------------------
void initCurrentSensor() {
  analogReadResolution(12);
  analogSetPinAttenuation(CURRENT_PIN, ADC_11db);

  float sum = 0;
  for (int i = 0; i < 500; i++) {
    float v = (analogRead(CURRENT_PIN) / (float)ADC_MAX_VALUE) * VREF;
    sum += v;
    delay(2);
  }
  currentOffset = sum / 500.0f;
}

float readCurrent() {
  float v = (analogRead(CURRENT_PIN) / (float)ADC_MAX_VALUE) * VREF;
  return (v - currentOffset) / SENSOR_SENSITIVITY;
}

void gestionarCorriente() {
  samples[sampleIndex++] = readCurrent();
  if (sampleIndex >= WINDOW_SIZE) sampleIndex = 0;

  static unsigned long t = 0;
  if (millis() - t > 200) {
    t = millis();

    float sum = 0;
    for (int i = 0; i < WINDOW_SIZE; i++) sum += samples[i]*samples[i];
    currentRMS = sqrt(sum / WINDOW_SIZE);

    Serial.print("Corriente RMS: ");
    Serial.println(currentRMS);

    if (estadoActual == LIMPIANDO && currentRMS > LIMITE_SOBRECORRIENTE_RMS) {
      Serial.println("FALLO: Sobrecorriente");
      estadoActual = FALLO;
    }
  }
}

// -------------------------
// Botón (flanco)
// -------------------------
void gestionarBoton() {
  static bool last = HIGH;
  bool now = digitalRead(BUTTON_PIN);

  if (last == HIGH && now == LOW) {
    if (millis() - tUltimoBoton > DEBOUNCE_MS) {
      tUltimoBoton = millis();

      Serial.println("=== REINICIO MANUAL ===");

      estadoActual = LIMPIANDO;
      tInicioEstado = millis();
    }
  }
  last = now;
}

// -------------------------
// Ciclo principal
// -------------------------
void gestionarCiclo() {
  unsigned long now = millis();

  switch (estadoActual) {

    case ESPERA:
      setRGB(1, 0, 0); // 🔴 Rojo
      setRelay(false);

      if (now - tInicioEstado >= TIEMPO_ESPERA_MS) {
        Serial.println("→ LIMPIANDO");
        estadoActual = LIMPIANDO;
        tInicioEstado = now;
      }
      break;

    case LIMPIANDO:
      setRGB(0, 0, 1); // 🔵 Azul
      setRelay(true);

      if (now - tInicioEstado >= TIEMPO_LIMPIEZA_MS) {
        Serial.println("→ FINALIZADO");
        estadoActual = FINALIZADO;
        tInicioEstado = now;
      }
      break;

    case FINALIZADO:
      setRGB(0, 1, 0); // 🟢 Verde
      setRelay(false);

      if (now - tInicioEstado >= TIEMPO_FINAL_MS) {
        Serial.println("→ ESPERA");
        estadoActual = ESPERA;
        tInicioEstado = now;
      }
      break;

    case FALLO:
      setRGB(1, 0, 1); // 🟣 Morado
      setRelay(false);
      break;
  }
}

// -------------------------
// Setup / Loop
// -------------------------
void setup() {
  Serial.begin(115200);

  pinMode(RELAY1_PIN, OUTPUT);
  pinMode(RELAY2_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  pinMode(LED_R_PIN, OUTPUT);
  pinMode(LED_G_PIN, OUTPUT);
  pinMode(LED_B_PIN, OUTPUT);

  sensors.begin();
  initCurrentSensor();

  estadoActual = ESPERA;
  tInicioEstado = millis();
}

void loop() {
  gestionarBoton();
  gestionarCorriente();
  gestionarCiclo();

  delay(20);
}
